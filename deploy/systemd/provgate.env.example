# Copy to ~/.config/provgate/provgate.env, fill in real values, then: chmod 600 it.
# NEVER commit the filled-in file. Losing PROVGATE_SECRET_KEY means re-entering every
# class's credentials.
#
# This file holds only secrets/optional overrides. Non-secret paths (PROVGATE_DB_PATH)
# are set in provgate.service via StateDirectory, so they are not repeated here.

# Fernet master key that decrypts stored credentials. Generate once with:
#   uv run provgate keygen
PROVGATE_SECRET_KEY=replace-me

# Optional: post a summary to a Discord/Slack-compatible incoming webhook after each pass.
# PROVGATE_WEBHOOK_URL=https://...
